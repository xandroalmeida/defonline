---
# Template do Ansible Vault — copie para `vault.yml` e cifre com:
#   cd infra/ansible
#   cp inventories/homolog/group_vars/vault.yml.example inventories/homolog/group_vars/vault.yml
#   # preencha os valores reais
#   ansible-vault encrypt inventories/homolog/group_vars/vault.yml
#
# Senha do vault: grave em ~/.ansible-vault-pass-homolog (chmod 600), ou use --ask-vault-pass.
# NÃO comitar `vault.yml` em texto claro — apenas a versão cifrada.

# PostgreSQL (gere com `openssl rand -base64 32`)
vault_db_app_password: "REPLACE_ME"
vault_db_backup_password: "REPLACE_ME"
vault_db_superuser_password: "REPLACE_ME"

# Backblaze B2 — Application Key (https://secure.backblaze.com/app_keys.htm)
# Crie com escopo restrito ao bucket `defonline-backups-homolog`.
vault_b2_app_key_id: "REPLACE_ME"
vault_b2_app_key: "REPLACE_ME"

# GPG passphrase usado para cifrar pg_dump (gere com `openssl rand -base64 32`).
# A chave GPG própria é gerada por scripts/gen-backup-gpg-key.sh e instalada na VPS.
vault_backup_gpg_passphrase: "REPLACE_ME"

# Telegram bot (criado via @BotFather; ADR-004 §1.5)
vault_telegram_bot_token: "0000000000:REPLACE_ME"
vault_telegram_chat_id_homolog: "-1000000000000"

# GHCR pull token — Personal Access Token com escopo read:packages.
# Se o repo for público, pode ser vazio.
vault_ghcr_pull_token: ""
