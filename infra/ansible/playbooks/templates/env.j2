# Gerado pelo Ansible em {{ ansible_date_time.iso8601 }} — NÃO editar manualmente.
APP_NAME=DEFOnline
APP_ENV={{ app_env }}
APP_KEY={{ vault_app_key | default('') }}
APP_DEBUG={{ app_debug | string | lower }}
APP_URL={{ app_url }}
APP_VERSION={{ app_version }}

APP_LOCALE={{ app_locale }}
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=stdout,daily
LOG_LEVEL={{ log_level }}
LOG_DAILY_DAYS=90

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE={{ postgres_db }}
DB_USERNAME={{ postgres_user }}
DB_PASSWORD={{ db_app_password }}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER={{ mail_mailer }}
MAIL_FROM_ADDRESS="noreply@{{ app_domain }}"
MAIL_FROM_NAME="DEFOnline"

TELEGRAM_BOT_TOKEN={{ telegram_bot_token }}
TELEGRAM_CHAT_ID={{ telegram_chat_id }}

# Postgres credentials para containers (POSTGRES_* + APP_DB_*)
POSTGRES_SUPERUSER={{ postgres_superuser }}
POSTGRES_SUPERUSER_PASSWORD={{ db_superuser_password }}
APP_DB_USER={{ postgres_user }}
APP_DB_PASSWORD={{ db_app_password }}
BACKUP_DB_USER={{ postgres_backup_user }}
BACKUP_DB_PASSWORD={{ db_backup_password }}
