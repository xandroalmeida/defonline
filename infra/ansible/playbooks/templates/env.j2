# Gerado pelo Ansible em {{ ansible_date_time.iso8601 }} — NÃO editar manualmente.
APP_NAME=DEFOnline
APP_ENV={{ app_env }}
APP_KEY={{ vault_app_key | default('') }}
APP_DEBUG={{ app_debug | string | lower }}
APP_URL={{ app_url }}
APP_VERSION={{ app_version }}

APP_LOCALE={{ app_locale }}
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=stdout,daily
LOG_LEVEL={{ log_level }}
LOG_DAILY_DAYS=90

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE={{ postgres_db }}
DB_USERNAME={{ postgres_user }}
DB_PASSWORD={{ db_app_password }}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER={{ mail_mailer }}
# `mail_from_address` é override explícito; quando ausente, cai no padrão
# `noreply@{{ app_domain }}`. Em homol/prod a separação importa: o domínio
# verificado no provedor de email (Resend, IDR-007) pode ser diferente do
# `app_domain` (ex.: xandrix.com.br raiz vs defonline.xandrix.com.br do site).
MAIL_FROM_ADDRESS="{{ mail_from_address | default('noreply@' + app_domain) }}"
MAIL_FROM_NAME="DEFOnline"

# Resend — provedor de email transacional (IDR-007). Chave vazia quando o
# `mail_mailer` for `log` ou `array` (não há entrega real); preencher via
# vault somente em ambientes que usam `mail_mailer=resend`.
RESEND_API_KEY={{ resend_api_key | default('') }}

TELEGRAM_BOT_TOKEN={{ telegram_bot_token }}
TELEGRAM_CHAT_ID={{ telegram_chat_id }}

# RFB — Consulta de CNPJ (STORY-018 / IDR-004 / IDR-006)
# `provider` é selecionável entre mock | cnpja | receitaws. Em ambientes reais
# (homol/prod), default vem de `rfb_provider` em group_vars/vars.yml.
# Chaves de API ficam no Vault cifrado (group_vars/all/vault.yml).
RFB_PROVIDER={{ rfb_provider | default('mock') }}
RFB_TIMEOUT={{ rfb_timeout | default(5) }}
RFB_CACHE_TTL={{ rfb_cache_ttl | default(300) }}
RFB_CNPJA_BASE_URL={{ rfb_cnpja_base_url | default('https://open.cnpja.com') }}
RFB_CNPJA_API_KEY={{ rfb_cnpja_api_key | default('') }}
RFB_CNPJA_RATE_LIMIT_PER_MINUTE={{ rfb_cnpja_rate_limit_per_minute | default(3) }}
RFB_RECEITAWS_BASE_URL={{ rfb_receitaws_base_url | default('https://receitaws.com.br/v1') }}
RFB_RECEITAWS_API_KEY={{ rfb_receitaws_api_key | default('') }}
RFB_RECEITAWS_RATE_LIMIT_PER_MINUTE={{ rfb_receitaws_rate_limit_per_minute | default(3) }}

# Postgres credentials para containers (POSTGRES_* + APP_DB_*)
POSTGRES_SUPERUSER={{ postgres_superuser }}
POSTGRES_SUPERUSER_PASSWORD={{ db_superuser_password }}
APP_DB_USER={{ postgres_user }}
APP_DB_PASSWORD={{ db_app_password }}
BACKUP_DB_USER={{ postgres_backup_user }}
BACKUP_DB_PASSWORD={{ db_backup_password }}
