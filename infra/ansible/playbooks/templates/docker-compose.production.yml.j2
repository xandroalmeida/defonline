# Gerado pelo Ansible — topologia produção/homologação (ADR-002 + ADR-005).
# Sem Mailpit; com Caddy 2 na borda + TLS Let's Encrypt automático.
name: defonline

x-app: &app-base
  image: "{{ container_registry }}/{{ container_image }}:{{ app_version }}"
  working_dir: /var/www/html
  env_file:
    - {{ deploy_dir }}/.env
  depends_on:
    db:
      condition: service_healthy
  restart: unless-stopped

services:
  caddy:
    image: {{ caddy_image }}
    container_name: defonline-caddy
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - {{ deploy_dir }}/caddy:/etc/caddy:ro
      - caddy_data:/data
      - caddy_config:/config
      - caddy_logs:/var/log/caddy
    depends_on: [web]
    restart: unless-stopped

  web:
    <<: *app-base
    container_name: defonline-web
    environment:
      PROCESS_TYPE: web
    expose:
      - "8000"
    command: >
      sh -c "php artisan serve --host=0.0.0.0 --port=8000"

  worker:
    <<: *app-base
    container_name: defonline-worker
    environment:
      PROCESS_TYPE: worker
    command: >
      sh -c "php artisan queue:work --queue=pdf,emails,lgpd,default
             --tries=3 --backoff=60,180,600 --max-time=3600"

  scheduler:
    <<: *app-base
    container_name: defonline-scheduler
    environment:
      PROCESS_TYPE: scheduler
    command: >
      sh -c "php artisan schedule:work"

  db:
    image: {{ postgres_image }}
    container_name: defonline-db
    environment:
      POSTGRES_DB: {{ postgres_db }}
      POSTGRES_USER: {{ postgres_superuser }}
      POSTGRES_PASSWORD: {{ db_superuser_password }}
      APP_DB_USER: {{ postgres_user }}
      APP_DB_PASSWORD: {{ db_app_password }}
      BACKUP_DB_USER: {{ postgres_backup_user }}
      BACKUP_DB_PASSWORD: {{ db_backup_password }}
      TZ: America/Sao_Paulo
      PGTZ: America/Sao_Paulo
    command: >
      postgres
      -c shared_preload_libraries=pg_stat_statements
      -c log_min_duration_statement=1000ms
      -c log_timezone=America/Sao_Paulo
      -c timezone=America/Sao_Paulo
      -c password_encryption=scram-sha-256
    volumes:
      - pgdata:/var/lib/postgresql
      - {{ deploy_dir }}/postgres/initdb:/docker-entrypoint-initdb.d:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_superuser }} -d {{ postgres_db }}"]
      interval: 5s
      timeout: 5s
      retries: 20
      start_period: 30s
    restart: unless-stopped

volumes:
  pgdata:
    name: defonline_pgdata
  caddy_data:
    name: defonline_caddy_data
  caddy_config:
    name: defonline_caddy_config
  caddy_logs:
    name: defonline_caddy_logs
