# Variáveis de ambiente para testes (APP_ENV=testing).
#
# Laravel detecta APP_ENV=testing (vindo do phpunit.xml) e carrega ESTE arquivo
# em vez de `.env` (Illuminate\Foundation\Bootstrap\LoadEnvironmentVariables).
# Espelha `.env` local com 3 diferenças:
#
#  1. APP_ENV=testing (consistência com phpunit.xml).
#  2. DB_DATABASE=defonline_test — banco dedicado pra RefreshDatabase NÃO
#     derrubar o `defonline` que serve smoke manual na UI. Bug rastreado em
#     2026-05-23 (STORY-015): o force=true do phpunit.xml não vence o
#     $_SERVER carregado do .env, então a override real precisa vir por aqui.
#  3. CACHE_STORE/SESSION_DRIVER/QUEUE_CONNECTION em modo in-memory pra
#     testes não dependerem de tabelas auxiliares no schema migrado.
#
# Versionado (não está no .gitignore) — CI lê pelo mesmo mecanismo.

APP_NAME=DEFOnline
APP_ENV=testing
APP_KEY=base64:7gf3GPBbCPBAFBDe0OJnHWkXyTkT5LnIXYA+7QIwqHg=
APP_DEBUG=true
APP_URL=http://localhost:8090
APP_VERSION=testing

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=stdout,daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=1

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=defonline_test
DB_USERNAME=defonline_app
DB_PASSWORD=defonline_app_secret_local
DB_SUPERUSER=postgres
DB_SUPERUSER_PASSWORD=postgres_secret_local

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=array

MAIL_MAILER=array
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="hello@defonline.local"
MAIL_FROM_NAME="${APP_NAME}"

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
