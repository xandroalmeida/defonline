<?xml version="1.0" encoding="UTF-8"?>
<!--
    Configuração de cobertura DEDICADA ao núcleo de domínio (STORY-010 CA-5).

    Quando app/Domain existir (nasce no EPIC-001), o pre-push hook e o job
    test-coverage do CI invocam:

        ./vendor/bin/pest configuration=phpunit-domain.xml coverage min=98

    O elemento source aqui restringe a medição a app/Domain. Assim o gate de
    98 por cento só olha o núcleo, e o gate de 80 por cento (phpunit.xml
    padrão) continua olhando todo o resto. ADR-006 secao 3.1 + quality
    standards secao 1.1.

    Não é exigido rodar enquanto a pasta não existe. O script detecta com
    o teste de diretório.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="All">
            <directory>tests/Unit</directory>
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>app/Domain</directory>
        </include>
    </source>

    <php>
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <env name="BROADCAST_CONNECTION" value="null" force="true"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <env name="MAIL_MAILER" value="array" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <env name="TELEGRAM_BOT_TOKEN" value="" force="true"/>
        <env name="PULSE_ENABLED" value="false" force="true"/>
        <env name="TELESCOPE_ENABLED" value="false" force="true"/>
        <env name="NIGHTWATCH_ENABLED" value="false" force="true"/>
    </php>
</phpunit>
