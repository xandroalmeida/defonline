APP_NAME=DEFOnline
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8090
APP_VERSION=dev

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=stdout,daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=90

# Database
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=defonline
DB_USERNAME=defonline_app
DB_PASSWORD=defonline_app_secret_local
DB_SUPERUSER=postgres
DB_SUPERUSER_PASSWORD=postgres_secret_local

# Sessions / cache / queue — todos no Postgres (ADR-001 + ADR-002)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mail — em local vai para Mailpit (ADR-002)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="hello@defonline.local"
MAIL_FROM_NAME="${APP_NAME}"

# Telegram (canal `log` em local, sem internet)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

VITE_APP_NAME="${APP_NAME}"
