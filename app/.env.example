APP_NAME=DEFOnline
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8090
APP_VERSION=dev

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=stdout,daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=90

# Database
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=defonline
DB_USERNAME=defonline_app
DB_PASSWORD=defonline_app_secret_local
DB_SUPERUSER=postgres
DB_SUPERUSER_PASSWORD=postgres_secret_local

# Sessions / cache / queue — todos no Postgres (ADR-001 + ADR-002)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mail — em local vai para Mailpit (ADR-002)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="hello@defonline.local"
MAIL_FROM_NAME="${APP_NAME}"

# Telegram (canal `log` em local, sem internet)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend — provedor de email transacional em homol/prod (IDR-007).
# Local usa MAIL_MAILER=smtp + Mailpit (não precisa de chave). A variável
# precisa estar declarada porque config('services.resend.key') lê dela.
RESEND_API_KEY=

# RFB — Consulta de CNPJ (STORY-015 + IDR-004/005/006)
# `mock` é o default e cobre desenvolvimento/testes. STORY-018 ativa cnpja/receitaws.
RFB_PROVIDER=mock
RFB_TIMEOUT=5
RFB_CACHE_TTL=300
RFB_CNPJA_BASE_URL=https://open.cnpja.com
RFB_CNPJA_API_KEY=
RFB_CNPJA_RATE_LIMIT_PER_MINUTE=3
RFB_RECEITAWS_BASE_URL=https://receitaws.com.br/v1
RFB_RECEITAWS_API_KEY=
RFB_RECEITAWS_RATE_LIMIT_PER_MINUTE=3

VITE_APP_NAME="${APP_NAME}"
