<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <!-- UnitPure: testes que NÃO tocam DB nem rede. Rodam offline em qualquer
             ambiente (CI sem Postgres, pre-push hook, IDE). ADR-006 §3.1. -->
        <testsuite name="UnitPure">
            <directory>tests/Unit</directory>
        </testsuite>

        <!-- Domain: testes de núcleo de regra de negócio (app/Domain). Pure unit,
             sem DB nem rede. Cobertura medida com gate ≥ 98% (phpunit-domain.xml).
             Introduzido na STORY-028 (motor de cálculo). -->
        <testsuite name="Domain">
            <directory>tests/Domain</directory>
        </testsuite>

        <!-- Feature: tocam Postgres real (RefreshDatabase) + Livewire + middlewares.
             Exigem `docker compose up db` ANTES de rodar. Cobrados no pre-push hook. -->
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>

        <!-- Atalho equivalente a UnitPure + Domain + Feature. -->
        <testsuite name="All">
            <directory>tests/Unit</directory>
            <directory>tests/Domain</directory>
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>app</directory>
        </include>
        <exclude>
            <!-- Scaffold do Laravel sem lógica nossa — excluído da cobertura
                 (STORY-010): o gate mede só o código que ESCREVEMOS. Quando essas
                 classes ganharem código próprio (BaseController no EPIC-002),
                 tirar daqui. -->
            <file>app/Http/Controllers/Controller.php</file>
        </exclude>
    </source>

    <!-- Cobertura: medir via flag explícita no CLI com PCOV ou Xdebug instalado.
         Gate (mínimo 80% geral, 98% em app/Domain quando nascer) vive no pre-push
         hook e no job test-coverage do pr.yml (ADR-006 §3.1 + quality-standards). -->

    <php>
        <!-- APP_ENV=testing dispara LoadEnvironmentVariables a carregar
             `.env.testing` em vez de `.env`. Toda a configuração de testes
             (DB_DATABASE=defonline_test, CACHE_STORE=array, BCRYPT_ROUNDS=4,
             MAIL_MAILER=array, etc.) vive lá — não aqui. Tentei force="true"
             para essas chaves antes e descobri que phpunit só seta $_ENV e
             getenv(), não $_SERVER; Laravel resolve env() via $_SERVER, então
             o .env (com APP_ENV=local) sempre vencia. Bug rastreado em
             2026-05-23 (STORY-015): RefreshDatabase rodava contra o banco
             `defonline` do smoke manual, apagando dados do PO em cada pre-push. -->
        <env name="APP_ENV" value="testing" force="true"/>
    </php>
</phpunit>
