<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <!-- UnitPure: testes que NÃO tocam DB nem rede. Rodam offline em qualquer
             ambiente (CI sem Postgres, pre-push hook, IDE). ADR-006 §3.1. -->
        <testsuite name="UnitPure">
            <directory>tests/Unit</directory>
        </testsuite>

        <!-- Feature: tocam Postgres real (RefreshDatabase) + Livewire + middlewares.
             Exigem `docker compose up db` ANTES de rodar. Cobrados no pre-push hook. -->
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>

        <!-- Atalho equivalente a UnitPure + Feature. -->
        <testsuite name="All">
            <directory>tests/Unit</directory>
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>app</directory>
        </include>
        <exclude>
            <!-- Scaffold do Laravel sem lógica nossa — excluído da cobertura
                 (STORY-010): o gate mede só o código que ESCREVEMOS. Quando essas
                 classes ganharem código próprio (User real no EPIC-001, BaseController
                 no EPIC-002), tirar daqui. -->
            <file>app/Models/User.php</file>
            <file>app/Http/Controllers/Controller.php</file>
        </exclude>
    </source>

    <!-- Cobertura: medir via flag explícita no CLI com PCOV ou Xdebug instalado.
         Gate (mínimo 80% geral, 98% em app/Domain quando nascer) vive no pre-push
         hook e no job test-coverage do pr.yml (ADR-006 §3.1 + quality-standards). -->

    <php>
        <!-- Testing usa MESMO Postgres da app (ADR-001 + quality-standards):
             RefreshDatabase nivela cada teste. SQLite seria inconsistente com
             CITEXT, JSONB, BRIN, pg_stat_statements. -->
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <env name="BROADCAST_CONNECTION" value="null" force="true"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <env name="MAIL_MAILER" value="array" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <env name="TELEGRAM_BOT_TOKEN" value="" force="true"/>
        <env name="PULSE_ENABLED" value="false" force="true"/>
        <env name="TELESCOPE_ENABLED" value="false" force="true"/>
        <env name="NIGHTWATCH_ENABLED" value="false" force="true"/>
    </php>
</phpunit>
